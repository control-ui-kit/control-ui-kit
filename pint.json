{
    "preset": "laravel",
    "rules": {
        "fully_qualified_strict_types": false,
        "class_attributes_separation": {
            "elements": {
                "method": "one",
                "trait_import": "none"
            }
        },
        "concat_space": {
            "spacing": "one"
        },
        "return_type_declaration": {
            "space_before": "none"
        }
    },
    "exclude": [
        "legacy"
    ]
}
